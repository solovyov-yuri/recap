# Copy this file to config.yaml and adjust values as needed.
# Priority: CLI options > config.yaml > defaults.

# Paths
audio: data/meeting.wav
transcript: data/transcript.txt
summary: data/summary.txt

# Transcription
language: ru
whisper_model: large-v3

# Summarization provider: ollama | openai
provider: ollama

# Ollama settings (used when provider: ollama)
ollama_model: qwen3.5:latest

# OpenAI settings (used when provider: openai)
# Requires OPENAI_API_KEY env var.
openai_model: gpt-4o-mini
# openai_api_key: sk-...
# openai_base_url: https://api.openai.com/v1   # override for Azure / local endpoints
